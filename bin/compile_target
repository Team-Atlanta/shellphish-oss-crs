#!/bin/bash
# OSS-CRS glue: calls OSS-Fuzz's compile, then submits build output via libCRS.
# BUILD_OUTPUT_NAME is set by additional_env in crs.yaml to match the outputs field.
set -euo pipefail

compile

# For canonical build: package project directory + metadata, then exit.
# Must be before wrapper.py replacement so artifacts/out/ has real binaries.
# Equivalent to Shellphish's canonical_build rsync (preprocessing.yaml:593)
# + build_target__local() metadata (project.py:1158-1169).
if [ "${BUILD_OUTPUT_NAME:-}" = "build-canonical" ]; then
    CANONICAL_OUT="/tmp/canonical-build"
    mkdir -p "$CANONICAL_OUT/artifacts/out" "$CANONICAL_OUT/artifacts/docker"
    cp -r "$OUT"/. "$CANONICAL_OUT/artifacts/out/"
    if [ -d "${OSS_CRS_PROJ_PATH:-}" ]; then
        cp "$OSS_CRS_PROJ_PATH/Dockerfile" "$CANONICAL_OUT/" 2>/dev/null || true
        cp "$OSS_CRS_PROJ_PATH/project.yaml" "$CANONICAL_OUT/" 2>/dev/null || true
        cp "$OSS_CRS_PROJ_PATH/build.sh" "$CANONICAL_OUT/" 2>/dev/null || true
    fi
    cat > "$CANONICAL_OUT/artifacts/out/shellphish_build_metadata.yaml" <<METAEOF
fuzzing_engine: ${FUZZING_ENGINE:-libfuzzer}
project_name: ${OSS_CRS_TARGET:-${PROJECT_NAME:-unknown}}
sanitizer: ${SANITIZER:-address}
source_repo_path: "$PWD"
architecture: ${ARCHITECTURE:-x86_64}
METAEOF
    libCRS submit-build-output "$CANONICAL_OUT" "build-canonical"
    exit 0
fi

# For LibFuzzer: replace harness binaries with wrapper.py symlinks.
# Shellphish's symlink_patch does this via TARGET_SPLIT_METADATA (unavailable in OSS-CRS).
if [ -f /shellphish/wrapper.py ] && [ "${FUZZING_ENGINE:-}" != "shellphish_aflpp" ]; then
    echo "OSS-CRS: installing wrapper.py symlinks for LibFuzzer harnesses"
    cp /shellphish/wrapper.py "$OUT/wrapper.py"
    chmod +x "$OUT/wrapper.py"
    for harness in "$OUT"/*; do
        [ -f "$harness" ] || continue
        [ -x "$harness" ] || continue
        name=$(basename "$harness")
        [[ "$name" == *.* ]] && continue
        [ "$name" = "wrapper" ] && continue
        [ "$name" = "llvm-symbolizer" ] && continue
        [ -L "$harness" ] && continue
        [ -f "$harness.instrumented" ] && continue
        mv "$harness" "$harness.instrumented"
        ln -s "$OUT/wrapper.py" "$harness"
        echo "OSS-CRS: wrapped $name -> wrapper.py"
    done
fi

libCRS submit-build-output "$OUT" "${BUILD_OUTPUT_NAME:-build}"
