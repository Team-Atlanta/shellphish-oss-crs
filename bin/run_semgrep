#!/bin/bash
# OSS-CRS glue: runs Shellphish's Semgrep analysis on target source.
# Reads: func-index (from previous build step)
# For C/C++: also reads clang-index (source + function JSONs)
# For JVM/Java: reads build-canonical (source from .shellphish_src), func-index has JSONs
# Writes: semgrep-report (vulnerability findings)
set -euo pipefail

# Download function index from previous build step
FUNC_INDEX_DIR="/tmp/func-index-input"
libCRS download-build-output func-index "$FUNC_INDEX_DIR"

# Language-dependent: source code and function JSON paths
LANG="${FUZZING_LANGUAGE:-c}"
case "$LANG" in
    jvm|java)
        # Java: source from build-canonical (.shellphish_src), function JSONs from func-index (antlr4-guy)
        CANONICAL_DIR="/tmp/canonical-input"
        mkdir -p "$CANONICAL_DIR"
        libCRS download-build-output build-canonical "$CANONICAL_DIR"

        FUNCTIONS_JSON_DIR="$FUNC_INDEX_DIR"

        REPO_PATH="$CANONICAL_DIR/artifacts/out/.shellphish_src"
        if [ ! -d "$REPO_PATH" ]; then
            REPO_PATH="$CANONICAL_DIR/artifacts/out/src"
        fi
        if [ ! -d "$REPO_PATH" ]; then
            echo "WARNING: No Java source found in canonical build, using /src"
            REPO_PATH="/src"
        fi
        ;;
    *)
        # C/C++: source and function JSONs from clang-indexer output
        CLANG_INDEX_DIR="/tmp/clang-index-input"
        libCRS download-build-output clang-index "$CLANG_INDEX_DIR"

        FUNCTIONS_JSON_DIR="$CLANG_INDEX_DIR/full"

        REPO_PATH="$CLANG_INDEX_DIR/src"
        if [ ! -d "$REPO_PATH" ]; then
            REPO_PATH="$CLANG_INDEX_DIR/original_workdir"
        fi
        if [ ! -d "$REPO_PATH" ]; then
            echo "WARNING: No source code found in clang-index output, using /src"
            REPO_PATH="/src"
        fi
        ;;
esac

# Determine rules directory based on language
LANG="${FUZZING_LANGUAGE:-c}"
case "$LANG" in
    c|c++) RULES_DIR="/shellphish/components/semgrep/rules/c" ;;
    jvm|java) RULES_DIR="/shellphish/components/semgrep/rules/java" ;;
    *) RULES_DIR="/shellphish/components/semgrep/rules/c" ;;
esac

OUTPUT_DIR="/tmp/semgrep-output"
mkdir -p "$OUTPUT_DIR"

echo "=== Running Semgrep Analysis ==="
echo "Repo: $REPO_PATH"
echo "Rules: $RULES_DIR"

python /shellphish/components/semgrep/semgrep.py \
    --repo_path "$REPO_PATH" \
    --rules_dir "$RULES_DIR" \
    --full_functions_indices "$FUNC_INDEX_DIR/indices.json" \
    --functions_json_dir "$FUNCTIONS_JSON_DIR" \
    --raw_findings_file_path "$OUTPUT_DIR/raw_findings.json" \
    --vulnerable_functions_file_path "$OUTPUT_DIR/vulnerable_functions.json" \
    --local-run || true

echo "=== Semgrep Analysis complete ==="
ls -la "$OUTPUT_DIR"

libCRS submit-build-output "$OUTPUT_DIR" "${BUILD_OUTPUT_NAME:-semgrep-report}"
