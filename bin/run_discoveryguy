#!/bin/bash
# OSS-CRS glue: DiscoveryGuy run module.
# Downloads build outputs, sets up project structure, launches DiscoveryGuy.
set -eu

HARNESS="${OSS_CRS_TARGET_HARNESS}"
SHARED="${OSS_CRS_SHARED_DIR:-/shared}"
PROJECT="${OSS_CRS_TARGET:-unknown}"
echo "=== DiscoveryGuy starting: harness=$HARNESS project=$PROJECT ==="

# --- Download build outputs ---
CANONICAL_DIR="/tmp/build-canonical"
mkdir -p "$CANONICAL_DIR"
libCRS download-build-output build-canonical "$CANONICAL_DIR"

RANKING_DIR="/tmp/code-swipe-ranking"
mkdir -p "$RANKING_DIR"
libCRS download-build-output code-swipe-ranking "$RANKING_DIR"

FUNC_INDEX_DIR="/tmp/func-index"
mkdir -p "$FUNC_INDEX_DIR"
libCRS download-build-output func-index "$FUNC_INDEX_DIR"

CLANG_INDEX_DIR="/tmp/clang-index"
mkdir -p "$CLANG_INDEX_DIR"
libCRS download-build-output clang-index "$CLANG_INDEX_DIR"

AUG_DIR="/tmp/augmented-metadata"
mkdir -p "$AUG_DIR"
libCRS download-build-output augmented-metadata "$AUG_DIR"

SPLIT_DIR="/tmp/split-metadata"
mkdir -p "$SPLIT_DIR"
libCRS download-build-output split-metadata "$SPLIT_DIR"

CODEQL_DIR="/tmp/codeql-analysis"
mkdir -p "$CODEQL_DIR"
libCRS download-build-output codeql-analysis "$CODEQL_DIR" 2>/dev/null || true
CODEQL_DB_ZIP="$CODEQL_DIR/sss-codeql-database.zip"

echo "Build outputs downloaded."

# --- Set up debug build structure ---
# DiscoveryGuy expects oss-fuzz project structure:
# $DEBUG_BUILDS_DIR/<build_id>/projects/<project_name>/artifacts/...
# In OSSCRS, we create this from build-canonical output.
DEBUG_BUILDS_DIR="/tmp/debug-builds"
OSS_FUZZ_REPO="/tmp/oss-fuzz-repo"
mkdir -p "$DEBUG_BUILDS_DIR" "$OSS_FUZZ_REPO"

# Create oss-fuzz repo structure (minimal, for project path resolution)
OSS_FUZZ_PROJ="$OSS_FUZZ_REPO/projects/$PROJECT"
mkdir -p "$OSS_FUZZ_PROJ"
# Copy project files from canonical build (Dockerfile, build.sh, project.yaml)
if [ -d "$CANONICAL_DIR/project_dir" ]; then
    cp -r "$CANONICAL_DIR/project_dir/"* "$OSS_FUZZ_PROJ/" 2>/dev/null || true
fi

# Create build configuration(s) matching what CrashChecker expects.
# CrashChecker matches build_configuration_id from split_metadata against directory names.
# Extract real build_configuration_ids from split metadata.
BUILD_IDS=$(python3 -c "
import json
with open('$SPLIT_DIR/target_split_metadata.json') as f:
    meta = json.load(f)
for k in meta.get('build_configurations', {}):
    print(k)
")
if [ -z "$BUILD_IDS" ]; then
    BUILD_IDS="address_default"
fi
echo "Build configuration IDs: $BUILD_IDS"

for BUILD_ID in $BUILD_IDS; do
BUILD_TARGET="$DEBUG_BUILDS_DIR/$BUILD_ID/projects/$PROJECT"
mkdir -p "$BUILD_TARGET/artifacts"
# canonical build output structure: $CANONICAL_DIR/artifacts/out/, not $CANONICAL_DIR/out/
if [ -d "$CANONICAL_DIR/artifacts/out" ]; then
    cp -r "$CANONICAL_DIR/artifacts/out" "$BUILD_TARGET/artifacts/out"
elif [ -d "$CANONICAL_DIR/out" ]; then
    cp -r "$CANONICAL_DIR/out" "$BUILD_TARGET/artifacts/out"
fi
mkdir -p "$BUILD_TARGET/artifacts/work"
# DiscoveryGuy reads harness source from artifacts/built_src/ (project.py:300).
# In original system, build_target__local() moves out/.shellphish_src → built_src/.
# We symlink instead since our canonical build preserves source at out/.shellphish_src/.
if [ -d "$BUILD_TARGET/artifacts/out/.shellphish_src" ]; then
    ln -sf out/.shellphish_src "$BUILD_TARGET/artifacts/built_src"
fi
# OSSFuzzProject.__init__ asserts Dockerfile exists in project path
# canonical build output has Dockerfile/build.sh/project.yaml at top level
for f in Dockerfile build.sh project.yaml; do
    if [ -f "$CANONICAL_DIR/$f" ]; then
        cp "$CANONICAL_DIR/$f" "$BUILD_TARGET/"
    fi
done
# Fallback: create minimal Dockerfile if not found
if [ ! -f "$BUILD_TARGET/Dockerfile" ]; then
    echo "FROM scratch" > "$BUILD_TARGET/Dockerfile"
fi
echo "Debug build [$BUILD_ID] at $BUILD_TARGET"
done  # end of for BUILD_ID loop

echo "Debug builds tree:"
find "$DEBUG_BUILDS_DIR" -maxdepth 4 -type d

# --- Find function ranking file ---
RANKING_FILE=""
for f in "$RANKING_DIR"/*.yaml "$RANKING_DIR"/*.yml "$RANKING_DIR"/ranking*; do
    if [ -f "$f" ]; then
        RANKING_FILE="$f"
        break
    fi
done
if [ -z "$RANKING_FILE" ]; then
    echo "WARNING: No ranking file found in $RANKING_DIR"
    ls -la "$RANKING_DIR/"
    # Try to find any yaml
    RANKING_FILE=$(find "$RANKING_DIR" -name "*.yaml" -o -name "*.yml" | head -1)
fi
echo "Ranking file: $RANKING_FILE"

# --- Environment ---
export OSSCRS_INTEGRATION_MODE=1
export LOCAL_RUN=True
export DELTA_MODE="${DELTA_MODE:-False}"
export DISCO_GUY_FROM="${DISCO_GUY_FROM:-POIS}"

# LLM configuration
export USE_LLM_API=1
export AIXCC_LITELLM_HOSTNAME="${OSS_CRS_LLM_API_URL:-${AIXCC_LITELLM_HOSTNAME:-http://litellm.crs-shellphish:4000}}"
export LITELLM_KEY="${OSS_CRS_LLM_API_KEY:-${LITELLM_KEY:-}}"
export OPENAI_API_KEY="${LITELLM_KEY}"
export OPENAI_API_BASE="${AIXCC_LITELLM_HOSTNAME}"

# Telemetry: disable
export OTEL_SDK_DISABLED="${OTEL_SDK_DISABLED:-true}"

# Neo4j
export ANALYSIS_GRAPH_BOLT_URL="${ANALYSIS_GRAPH_BOLT_URL:-bolt://neo4j:helloworldpdt@neo4j.crs-shellphish:7687}"

# CodeQL server (run phase sidecar container)
export CODEQL_SERVER_URL="${CODEQL_SERVER_URL:-http://codeql-server.crs-shellphish-discoveryguy:4000}"

# --- Wait for AG init (populates Neo4j with callgraph data) ---
SHARED="${OSS_CRS_SHARED_DIR:-/shared}"
echo "Waiting for AG init..."
AG_WAIT=0
while [ $AG_WAIT -lt 300 ] && [ ! -f "$SHARED/ag_init_done" ]; do
    sleep 5
    AG_WAIT=$((AG_WAIT + 5))
done
[ -f "$SHARED/ag_init_done" ] && echo "AG init done." || echo "WARNING: AG init not completed in time, continuing without callgraph data."

# --- Wait for Neo4j ---
echo "Waiting for Neo4j..."
NEO4J_WAIT=0
while [ $NEO4J_WAIT -lt 60 ]; do
    if timeout 10 python3 -c "from neomodel import db; db.set_connection('${ANALYSIS_GRAPH_BOLT_URL}'); db.cypher_query('RETURN 1')" 2>&1; then echo "Neo4j connected."; break; fi
    echo "Neo4j not ready yet (attempt $((NEO4J_WAIT/5+1)))"
    sleep 5
    NEO4J_WAIT=$((NEO4J_WAIT + 5))
done

# Output directories
CRASH_DIR="/tmp/disco-crashes"
REPORT_DIR="/tmp/disco-reports"
SEEDS_DIR="/tmp/disco-seeds"
mkdir -p "$CRASH_DIR" "$REPORT_DIR" "$SEEDS_DIR"

# --- Register PoV submission directory ---
# libCRS watches this dir and submits any files as PoVs
libCRS register-submit-dir pov "$CRASH_DIR" &

echo "=== Launching DiscoveryGuy ==="
echo "Mode: $DISCO_GUY_FROM"
echo "Debug builds: $DEBUG_BUILDS_DIR"
echo "Ranking: $RANKING_FILE"

# --- Launch DiscoveryGuy ---
cd /src
python -u run.py \
    --project_id "$PROJECT" \
    --target_metadata "$AUG_DIR/augmented_metadata.json" \
    --aggregated_harness_info_file "$SPLIT_DIR/target_split_metadata.json" \
    --function_index "$FUNC_INDEX_DIR/indices.json" \
    --target_functions_jsons_dir "$CLANG_INDEX_DIR/full" \
    --oss_fuzz_repo_path "$OSS_FUZZ_REPO" \
    --oss_fuzz_debug_targets_folder "$DEBUG_BUILDS_DIR" \
    --function_ranking "$RANKING_FILE" \
    --backup_seeds_vault "$SEEDS_DIR" \
    --report_dir "$REPORT_DIR" \
    --crash_dir_pass_to_pov "$CRASH_DIR" \
    --crash_metadata_dir_pass_to_pov "$CRASH_DIR" \
    ${CODEQL_DB_ZIP:+--codeql_db_path "$CODEQL_DB_ZIP"} \
    2>&1 | tee /tmp/discoveryguy_run.log
