#!/bin/bash
# OSS-CRS glue: LibFuzzer build entry point.
set -uo pipefail
source "$(dirname "$0")/shellphish_build_helpers.sh"

setup_ccache
compile; RETCODE=$?
run_post_build_commands "$OUT"

# wrapper.py symlink replacement (replaces Shellphish's symlink_patch which
# depends on TARGET_SPLIT_METADATA, unavailable in OSS-CRS)
if [ -f /shellphish/wrapper.py ]; then
    echo "OSS-CRS: installing wrapper.py symlinks for LibFuzzer harnesses"
    cp /shellphish/wrapper.py "$OUT/wrapper.py"
    chmod +x "$OUT/wrapper.py"
    for harness in "$OUT"/*; do
        [ -f "$harness" ] || continue
        [ -x "$harness" ] || continue
        name=$(basename "$harness")
        [[ "$name" == *.* ]] && continue
        [ "$name" = "wrapper" ] && continue
        [ "$name" = "llvm-symbolizer" ] && continue
        [ -L "$harness" ] && continue
        [ -f "$harness.instrumented" ] && continue
        mv "$harness" "$harness.instrumented"
        ln -s "$OUT/wrapper.py" "$harness"
        echo "OSS-CRS: wrapped $name -> wrapper.py"
    done
fi

libCRS submit-build-output "$OUT" "${BUILD_OUTPUT_NAME:-build-libfuzzer}"
exit $RETCODE
