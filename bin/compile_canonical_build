#!/bin/bash
# OSS-CRS glue: canonical build entry point.
# Replicates Shellphish's canonical_build (preprocessing.yaml:505-593).
set -uo pipefail
source "$(dirname "$0")/shellphish_build_helpers.sh"

setup_ccache
compile; RETCODE=$?

# preserve source (canonical_build uses --preserve-built-src-dir, project.py:1042)
cp -r /src /out/.shellphish_src 2>/dev/null || true

run_post_build_commands "$OUT"

# Package canonical project directory
CANONICAL_OUT="/tmp/canonical-build"
mkdir -p "$CANONICAL_OUT/artifacts/out" "$CANONICAL_OUT/artifacts/docker"
cp -r "$OUT"/. "$CANONICAL_OUT/artifacts/out/"
if [ -d "${OSS_CRS_PROJ_PATH:-}" ]; then
    cp "$OSS_CRS_PROJ_PATH/Dockerfile" "$CANONICAL_OUT/" 2>/dev/null || true
    cp "$OSS_CRS_PROJ_PATH/project.yaml" "$CANONICAL_OUT/" 2>/dev/null || true
    # [OSS-CRS glue] Remove fields not in Shellphish's OSSFuzzProjectYAML model (extra="forbid")
    sed -i '/^rts_mode:/d; /^inc_build:/d; /^auto_profile:/d; /^experimental:/d' "$CANONICAL_OUT/project.yaml" 2>/dev/null || true
    # Add shellphish_project_name if not present
    if ! grep -q "shellphish_project_name:" "$CANONICAL_OUT/project.yaml" 2>/dev/null; then
        printf '\nshellphish_project_name: %s\n' "${OSS_CRS_TARGET:-${PROJECT_NAME:-unknown}}" >> "$CANONICAL_OUT/project.yaml"
    fi
    cp "$OSS_CRS_PROJ_PATH/build.sh" "$CANONICAL_OUT/" 2>/dev/null || true
fi

# Build harness list using Shellphish's get_fuzz_targets() detection logic
# (from extract_bc.py — stdlib only, no external deps)
HARNESS_LIST=$(python3 -c "
import os, re, stat
from pathlib import Path

ALLOWED_FUZZ_TARGET_EXTENSIONS = ['', '.exe']
FUZZ_TARGET_SEARCH_STRING = b'LLVMFuzzerTestOneInput'
VALID_TARGET_NAME_REGEX = re.compile(r'^[a-zA-Z0-9_-]+\$')
BLOCKLISTED_TARGET_NAME_REGEX = re.compile(r'^(jazzer_driver.*)\$')

path = '$OUT'
targets = []
for f in os.listdir(path):
    fp = os.path.join(path, f)
    if not os.path.isfile(fp) or not os.access(fp, os.X_OK):
        continue
    _, ext = os.path.splitext(f)
    if ext not in ALLOWED_FUZZ_TARGET_EXTENSIONS:
        continue
    if BLOCKLISTED_TARGET_NAME_REGEX.match(f) or not VALID_TARGET_NAME_REGEX.match(f):
        continue
    with open(fp, 'rb') as fh:
        if FUZZ_TARGET_SEARCH_STRING in fh.read():
            targets.append(f)
print(', '.join('\"' + t + '\"' for t in targets))
" 2>/dev/null || echo "")

# Build metadata (project.py:1158-1169)
cat > "$CANONICAL_OUT/artifacts/out/shellphish_build_metadata.yaml" <<METAEOF
fuzzing_engine: ${FUZZING_ENGINE:-libfuzzer}
project_name: ${OSS_CRS_TARGET:-${PROJECT_NAME:-unknown}}
sanitizer: ${SANITIZER:-address}
source_repo_path: "$PWD"
architecture: ${ARCHITECTURE:-x86_64}
harnesses: [$HARNESS_LIST]
METAEOF

libCRS submit-build-output "$CANONICAL_OUT" "${BUILD_OUTPUT_NAME:-build-canonical}"
exit $RETCODE
